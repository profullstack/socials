{
  "name": "@profullstack/socials",
  "version": "0.1.0",
  "description": "Safe Playwright scaffolding for authorized social account login automation.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "socials": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "social",
    "automation",
    "playwright",
    "cookies",
    "session",
    "login"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/profullstack/socials.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "playwright": "^1.56.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
